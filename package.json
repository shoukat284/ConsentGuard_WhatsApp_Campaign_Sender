{
  "name": "consentguard-whatsapp-campaign-sender",
  "version": "2.0.5",
  "description": "Consent-based WhatsApp desktop campaign sender with suppression, scheduling, delivery reporting and safety controls",
  "main": "main.js",
  "author": "",
  "license": "ISC",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "check": "node scripts/check.js",
    "test": "node --test tests/*.test.js",
    "pack": "electron-builder --dir",
    "dist:win": "electron-builder --win nsis portable",
    "doctor": "node scripts/doctor.js"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "csv-parse": "^5.6.0",
    "handlebars": "^4.7.8",
    "nedb-promises": "^6.2.3",
    "node-cron": "^4.2.1",
    "qrcode": "^1.5.4",
    "whatsapp-web.js": "^1.34.7"
  },
  "devDependencies": {
    "electron": "^43.1.1",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.consentguard.whatsappcampaignsender",
    "productName": "ConsentGuard WhatsApp Campaign Sender",
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "package.json",
      "node_modules/**/*",
      "!**/.wwebjs_auth/**",
      "!**/whatsapp-auth/**",
      "!tests/**",
      "!dist/**"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "engines": {
    "node": "^22.12.0 || ^24.0.0",
    "npm": "^10.0.0 || ^11.0.0"
  }
}
